{
  "name": "monster-realm",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "24.13.1" },
    "ghcr.io/guiyomh/features/just:0": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "rustup target add wasm32-unknown-unknown && cargo install wasm-pack --version 0.15.0 --locked && just setup",
  "customizations": { "vscode": { "extensions": ["editorconfig.editorconfig"] } }
}
