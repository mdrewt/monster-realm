  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "fast-check": "^3.21.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "@biomejs/biome@2.5.1": true,
    "esbuild@0.25.12": true,
    "esbuild@0.21.5": true,
    "@swc/core@1.15.43": true
  }
