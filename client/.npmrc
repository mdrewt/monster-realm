# Enforce the pinned Node version at the client too: npm only walks .npmrc files
# from cwd upward to $HOME, and the repo root is not always an ancestor of the
# invocation cwd (e.g. git worktrees). Mirror the root engine-strict so
# `npm install` fails on a mismatched Node (client/package.json "engines").
engine-strict=true

# Supply-chain: wait 7 days before resolving NEWLY published package versions
# (npm >= 11.10 minimum release age; `npm ci` is unaffected -- it installs the
# lockfile verbatim). Satisfies semgrep npm-missing-minimum-release-age.
min-release-age = 7
