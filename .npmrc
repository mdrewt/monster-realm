# Enforce the pinned Node version: fail `npm install` on a mismatched Node
# (the package.json "engines" range) instead of merely warning.
# Node is pinned to 24.13.1 via asdf .tool-versions; see standards/language/node-ts.md.
engine-strict=true

# Supply-chain: wait 7 days before resolving NEWLY published package versions
# (npm >= 11.10 minimum release age; `npm ci` is unaffected -- it installs the
# lockfile verbatim). Satisfies semgrep npm-missing-minimum-release-age.
min-release-age = 7
